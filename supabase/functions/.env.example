# Edge Function secrets. Set these with:
#   supabase secrets set --env-file supabase/functions/.env
# (Do NOT commit the real .env. SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY /
#  SUPABASE_ANON_KEY are injected automatically by the platform — no need to set.)

# --- WhatsApp (Whapi) --- adapter stays stubbed until WHAPI_TOKEN is set
WHAPI_TOKEN=
WHAPI_BASE_URL=https://gate.whapi.cloud
# shared secret you also configure in the Whapi webhook URL (?secret=... or header)
WHATSAPP_WEBHOOK_SECRET=

# --- Google OAuth (ONE "Web application" client for Gmail send + Calendar read) ---
# ONE-TIME SETUP for the portal's one-click reconnect:
#   1. In Google Cloud Console the OAuth client must be type "Web application".
#   2. Add this Authorized redirect URI to that client:
#        https://<your-project-ref>.supabase.co/functions/v1/google-oauth-callback
#   3. Set GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET below.
# After that, admins reconnect Google from the Dashboard "Connections" card — no
# refresh token needed here (it's stored in the DB by the reconnect flow).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional seed/fallback. Leave blank once you've reconnected from the portal.
GOOGLE_REFRESH_TOKEN=

# --- Gmail (send) ---
GMAIL_SENDER=ops@wybalena.com
ALERT_EMAIL_TO=ashley@wybalena.com

# --- Google Calendar (read-only) ---
GOOGLE_CALENDAR_ID=

# --- health-check --- where broken-connection alerts go (defaults to ALERT_EMAIL_TO)
HEALTHCHECK_ALERT_TO=yashasvi@example.com
